# Source Database Configuration
SOURCE_DB_HOST=localhost
SOURCE_DB_PORT=5432
SOURCE_DB_NAME=source_db
SOURCE_DB_USER=postgres
SOURCE_DB_PASSWORD=postgres
SOURCE_DB_SSL=false
SOURCE_DB_POOL_SIZE=10
SOURCE_DB_TIMEOUT=30000

# Staging Database Configuration
STAGING_DB_HOST=localhost
STAGING_DB_PORT=5432
STAGING_DB_NAME=staging_db
STAGING_DB_USER=postgres
STAGING_DB_PASSWORD=postgres
STAGING_DB_SSL=false
STAGING_DB_POOL_SIZE=10
STAGING_DB_TIMEOUT=30000

# Target Database Configuration
TARGET_DB_HOST=localhost
TARGET_DB_PORT=5432
TARGET_DB_NAME=target_db
TARGET_DB_USER=postgres
TARGET_DB_PASSWORD=postgres
TARGET_DB_SSL=false
TARGET_DB_POOL_SIZE=10
TARGET_DB_TIMEOUT=30000

# Conversion Engine Configuration
BATCH_SIZE=1000
CHECKPOINT_INTERVAL=5000
MAX_RETRIES=3
RETRY_DELAY=1000
ENABLE_TRANSACTIONS=true
TIMEOUT_MS=60000

# Audit & Logging
LOG_LEVEL=info
AUDIT_RETENTION_DAYS=90
ENABLE_DATA_LINEAGE=true
LINEAGE_DB_HOST=localhost
LINEAGE_DB_PORT=5432

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL=30000

# State Management
STATE_STORAGE=redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
STATE_TTL=86400

# Application
NODE_ENV=development
APPLICATION_NAME=conversion-platform
APPLICATION_VERSION=1.0.0
ENABLE_DEBUG=false
